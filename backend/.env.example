# =====================
# 模型提供商配置
# =====================
# 可选值: ZHIPUAI (智谱GLM) | QWEN (通义千问)
AI_MODEL_PROVIDER=ZHIPUAI

# =====================
# OpenAI 兼容 API 配置
# =====================
# 智谱GLM: https://open.bigmodel.cn/api/paas/v4
# 通义千问: https://dashscope.aliyuncs.com/compatible-mode/v1
AI_OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
AI_API_KEY=your-api-key-here

# =====================
# 模型参数配置
# =====================
# 智谱模型: glm-4 | glm-4-plus | glm-4-air | glm-4-flash
# 通义千问: qwen-plus | qwen-turbo | qwen-max | qwen-long
AI_CHAT_MODEL=glm-4
AI_TEMPERATURE=0.7

# =====================
# Embedding 配置
# =====================
AI_EMBEDDING_MODEL=embedding-3

# =====================
# ChromaDB 配置
# =====================
CHROMA_COLLECTION=librarian-docs
CHROMA_TENANT=SpringAiTenant
CHROMA_DATABASE=SpringAiDatabase
CHROMA_HOST=http://localhost
CHROMA_PORT=8000

# =====================
# 服务配置
# =====================
SERVER_PORT=8080
